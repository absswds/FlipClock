<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme: edge-to-edge, pure black, no action bar.
         The actual UI is fully Compose; this theme only sets the window backdrop
         so there is no white flash before Compose draws. -->
    <style name="Theme.FlipClock" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
